# ─── Supabase ─────────────────────────────────────────────────────────────────
# Required. Get from: Supabase Dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ─── PostHog analytics (optional) ─────────────────────────────────────────────
# If unset, all analytics calls are no-ops.
# Get from: PostHog Dashboard → Project Settings → Project API Key
VITE_POSTHOG_KEY=phc_your_project_key
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Sentry error tracking (optional) ────────────────────────────────────────
# If unset, Sentry is not initialised.
# Get from: Sentry Dashboard → Settings → Projects → your-project → Client Keys
VITE_SENTRY_DSN=https://your-key@sentry.io/project-id
VITE_SENTRY_ENV=development

# ─── Feature flags (optional) ─────────────────────────────────────────────────
# Override defaults for local development. Values: "true" | "false"
# VITE_FLAG_INVESTMENT_MODE=true
# VITE_FLAG_FAMILY_INVITATIONS=true
# VITE_FLAG_AI_INSIGHTS=true
# VITE_FLAG_PWA_INSTALL_PROMPT=true
